<?xml version="1.0" encoding="UTF-8"?>
<schemalist>
  <schema id="@APP_ID@" path="/@APP_PATH@/">
    <key name="window-width" type="i">
      <default>800</default>
      <summary>Window width</summary>
      <description>The width of the main window</description>
    </key>
    
    <key name="window-height" type="i">
      <default>600</default>
      <summary>Window height</summary>
      <description>The height of the main window</description>
    </key>
    
    <key name="window-maximized" type="b">
      <default>false</default>
      <summary>Window maximized</summary>
      <description>Whether the window is maximized</description>
    </key>
    
    <key name="image-quality" type="i">
      <default>95</default>
      <range min="1" max="100"/>
      <summary>Image quality</summary>
      <description>Quality level for saved images (1-100)</description>
    </key>
    
    <key name="preserve-timestamps" type="b">
      <default>true</default>
      <summary>Preserve file timestamps</summary>
      <description>Keep original file creation and modification times</description>
    </key>
    
    <key name="secure-memory" type="b">
      <default>true</default>
      <summary>Secure memory</summary>
      <description>Clear image data from memory after processing</description>
    </key>

    <key name="allow-symlinks-dev" type="b">
      <default>false</default>
      <summary>Allow symlinks in development</summary>
      <description>Development-only setting to allow symbolic links for testing. Ignored in production builds for security.</description>
    </key>

    <!-- Metadata Removal Settings -->
    <key name="remove-gps" type="b">
      <default>true</default>
      <summary>Remove GPS/Location</summary>
      <description>Remove GPS coordinates and location data</description>
    </key>

    <key name="remove-camera" type="b">
      <default>true</default>
      <summary>Remove Camera Info</summary>
      <description>Remove camera make, model, and lens information</description>
    </key>

    <key name="remove-datetime" type="b">
      <default>true</default>
      <summary>Remove Date/Time</summary>
      <description>Remove photo capture date and time</description>
    </key>

    <key name="remove-software" type="b">
      <default>true</default>
      <summary>Remove Software Info</summary>
      <description>Remove software and editing history</description>
    </key>

    <key name="remove-author" type="b">
      <default>true</default>
      <summary>Remove Author/Copyright</summary>
      <description>Remove author, copyright, and contact information</description>
    </key>

    <!-- Version alert settings -->
    <key name="last-version-shown" type="s">
      <default>""</default>
      <summary>Last version shown in version alert</summary>
      <description>The version number of the last version alert shown to the user</description>
    </key>
  </schema>
</schemalist>